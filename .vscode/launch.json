{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Getting started (interactive)",
            "type": "php",
            "request": "launch",
            "program": "${workspaceFolder}/examples/getting-started.php",
            "cwd": "${workspaceFolder}",
            "externalConsole": true,
            "runtimeArgs": [
                "-dxdebug.mode=debug",
                "-dxdebug.start_with_request=yes"
            ]
        },
        {
            "name": "Getting started (--scenario)",
            "type": "php",
            "request": "launch",
            "program": "${workspaceFolder}/examples/getting-started.php",
            "args": ["--scenario"],
            "cwd": "${workspaceFolder}",
            "runtimeArgs": [
                "-dxdebug.mode=debug",
                "-dxdebug.start_with_request=yes"
            ]
        },
        {
            "name": "PHPUnit tests",
            "type": "php",
            "request": "launch",
            "program": "${workspaceFolder}/vendor/phpunit/phpunit/phpunit",
            "cwd": "${workspaceFolder}",
            "runtimeArgs": [
                "-dxdebug.mode=debug",
                "-dxdebug.start_with_request=yes"
            ]
        },
        {
            "name": "Listen for Xdebug",
            "type": "php",
            "request": "launch",
            "port": 9003
        }
    ]
}
